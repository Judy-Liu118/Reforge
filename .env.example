# Copy this file to `.env` and fill in real values. `.env` is in .gitignore;
# never commit real keys. If a key is accidentally pushed, rotate it
# (DeepSeek / OpenAI dashboards both expose a one-click revoke) and rewrite
# the commit with `git filter-repo` before force-pushing.

# ---------------------------------------------------------------------------
# Primary text LLM — used by planner / codegen (text) / reflection / eval
# ---------------------------------------------------------------------------
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=sk-REPLACE_WITH_YOUR_KEY
LLM_MODEL=deepseek-v4-pro

# ---------------------------------------------------------------------------
# Vision LLM — describe_image() role (OCR / structured transcription)
# Falls through to LLM_* if left empty. DashScope qwen3-vl-flash is cheap
# and fast for text extraction.
# ---------------------------------------------------------------------------
VISION_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
VISION_LLM_API_KEY=sk-REPLACE_WITH_YOUR_KEY
VISION_LLM_MODEL=qwen3-vl-flash

# ---------------------------------------------------------------------------
# Vision Judge — compare_images() role (strict rubric scoring)
# Falls through to VISION_LLM_* when empty. Use a STRONGER model here.
# Warning: thinking variants (e.g. qwen3-vl-32b-thinking) can hang
# indefinitely — their streaming responses keep the TCP alive past SDK
# timeout. Stick to non-thinking unless you've tested it.
# ---------------------------------------------------------------------------
VISION_JUDGE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
VISION_JUDGE_API_KEY=sk-REPLACE_WITH_YOUR_KEY
VISION_JUDGE_MODEL=qwen-vl-max

# ---------------------------------------------------------------------------
# Vision Codegen — used when the user supplies a target image (target.png
# in workspace) and the task matches visual-reproduction intent. The model
# sees the image directly via multimodal message, no describe_image needed.
# Falls through to LLM_* when empty (text codegen path).
# ---------------------------------------------------------------------------
CODEGEN_VISION_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
CODEGEN_VISION_API_KEY=sk-REPLACE_WITH_YOUR_KEY
CODEGEN_VISION_MODEL=qwen-vl-max

# ---------------------------------------------------------------------------
# Runtime Configuration
# ---------------------------------------------------------------------------
MAX_RETRY=3
EXECUTION_TIMEOUT=300

# Sandbox backend: "subprocess" (default, fast) or "docker" (hardened)
# REFORGE_SANDBOX_BACKEND=docker
